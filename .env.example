# PM2 Admin - Environment Configuration

# Bind address (default: 127.0.0.1)
HOST=127.0.0.1

# HTTP port (default: 4343)
PORT=4343

# Session signing secret.
# Auto-generated on first run if left blank, but setting it explicitly
# prevents all sessions from being invalidated on restart.
APP_SESSION_SECRET=

# Application environment label (shown in the UI)
APP_ENV=Production
