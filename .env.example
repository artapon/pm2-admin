# PM2 Admin - Environment Configuration

# Application Settings
APP_ENV=Production
HOST=localhost
PORT=7002

# Authentication (Legacy / Migration)
# Leave blank to use the new Web Setup Wizard on first run.
APP_USERNAME=
APP_PASSWORD=

# Session Security
# Generated automatically if left blank, but set here for persistence across restarts.
APP_SESSION_SECRET=

# Legacy Support Roles (Now migrated to SQLite)
# ITADMIN is converted to the 'support' role (if configured).
IT_APP_USERNAME=
IT_APP_PASSWORD=

# Feature Flags (Legacy - Role-based system preferred)
IS_ALLOW_CLONE=false
IS_ALLOW_LIST_PORT=true
